# PostgreSQL connection strings from Vercel Postgres (or any Postgres provider).
# Get these from: Vercel Dashboard > Storage > your Postgres db > ".env.local" tab
#
# DATABASE_URL  — pooled connection (via PgBouncer), used by the app at runtime
# DIRECT_URL    — direct connection, used by `prisma db push` during build
#                 (falls back to DATABASE_URL if not set)
#
# Example:
# DATABASE_URL=postgres://default:password@ep-pooled-host.neon.tech/dbname?sslmode=require&pgbouncer=true
# DIRECT_URL=postgres://default:password@ep-direct-host.neon.tech/dbname?sslmode=require
DATABASE_URL=
DIRECT_URL=
