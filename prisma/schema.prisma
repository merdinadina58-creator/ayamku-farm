// Uses PostgreSQL (Vercel Postgres) via driver adapter for serverless compatibility.
// Local dev note: set DATABASE_URL to a PostgreSQL connection string in .env or .env.local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Batch {
  id               String   @id @default(cuid())
  name             String
  terminNumber     Int
  arrivalDate      DateTime
  initialWeight    Float    // kg per ekor saat datang
  quantity         Int      // jumlah ekor awal
  status           String   @default("active") // active, harvested
  harvestDate      DateTime?
  harvestWeight    Float?   // kg per ekor saat panen
  harvestQuantity  Int?     // jumlah ekor yang dipanen
  sellingPricePerKg Float?  // harga jual per kg saat panen
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  feedRecords      FeedRecord[]
  weightRecords    WeightRecord[]
  mortalityRecords MortalityRecord[]
  equipment        Equipment[]
}

model FeedRecord {
  id         String   @id @default(cuid())
  batchId    String
  date       DateTime
  feedType   String   // jenis pakan (starter, grower, finisher, dll)
  quantityKg Float    // jumlah pakan dalam kg
  pricePerKg Float    // harga per kg
  notes      String?
  createdAt  DateTime @default(now())

  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model WeightRecord {
  id               String   @id @default(cuid())
  batchId          String
  date             DateTime
  averageWeightGram Float   // rata-rata berat dalam gram
  ageDays          Int      // umur dalam hari
  sampleCount      Int      @default(1) // jumlah sampel
  notes            String?
  createdAt        DateTime @default(now())

  batch            Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model MortalityRecord {
  id        String   @id @default(cuid())
  batchId   String
  date      DateTime
  quantity  Int      // jumlah ayam mati/afkir
  reason    String   // penyebab: sakit, stress, kecelakaan, afkir, lainnya
  notes     String?
  createdAt DateTime @default(now())

  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id   // appName, logoData (base64 data URL)
  value     String
  updatedAt DateTime @updatedAt
}

model Equipment {
  id           String   @id @default(cuid())
  name         String   // nama barang, mis. "Broiler Pelet", "Tempat Minum Otomatis"
  category     String   // kategori: Kandang, Peralatan Pakan & Minum, dll
  quantity     Int      // jumlah
  unit         String   @default("unit") // satuan: Sak, Karung, Liter, kg, dll
  unitPrice    Float    // harga per satuan (Rp)
  purchaseDate DateTime // tanggal pembelian
  notes        String?
  batchId      String?  // relasi ke Batch — peralatan dibeli per termin (nullable untuk data lama)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch        Batch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// Master daftar satuan (Sak, Karung, Liter, kg, dll).
// Pengguna bisa menambah satuan baru lewat UI; satuan tersimpan di sini
// agar tetap tersedia di dropdown pada sesi berikutnya.
model Unit {
  id        String   @id @default(cuid())
  name      String   @unique // nama satuan, mis. "Sak"
  createdAt DateTime @default(now())
}
